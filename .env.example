# ContainerClaw Environment Configuration

# Absolute path to the project root on the host machine
# Used for volume mounts and security profiles
PROJECT_DIR=.

# Agent Configuration
LLM_GATEWAY_URL=http://llm-gateway:8000
FLUSS_BOOTSTRAP_SERVERS=coordinator-server:9123
DEFAULT_MODEL=gemini-3-flash-preview
MAX_HISTORY_MESSAGES=100
MAX_TOOL_ROUNDS=30
CONCHSHELL_ENABLED=true
AUTONOMOUS_STEPS=-1

# LLM Gateway Configuration
LLM_GATEWAY_PORT=8000
RATE_LIMIT_RPM=60
MAX_TOKENS_PER_REQUEST=8192
ALLOWED_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash


# UI Configuration
UI_PORT=3000

# HuggingFace
HF_TOKEN=***